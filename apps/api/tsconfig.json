{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["./worker-configuration.d.ts"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "worker-configuration.d.ts"]
}
