{
  "name": "@agent-tutor/shared",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./consts": "./src/consts/index.ts",
    "./types": "./src/types/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "scripts": {
    "format": "prettier --check src",
    "lint": "pnpm run lint:code && pnpm run lint:type",
    "lint:code": "eslint src --max-warnings=0",
    "lint:type": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "echo \"No e2e tests for @agent-tutor/shared\"",
    "build": "tsup",
    "clean": "find . -name dist -prune -exec rm -r {} + 2>/dev/null || true",
    "clean:all": "pnpm run clean"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
